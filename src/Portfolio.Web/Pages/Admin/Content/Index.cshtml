@page "/admin/icerik"
@model Portfolio.Web.Pages.Admin.Content.IndexModel
@{
    ViewData["Title"] = "Site İçeriği";
}

<h1>Site İçeriği</h1>
<p class="admin-hint">Bu metinler sitenin ilgili bölümlerinde anında görünür. Her metnin Türkçe ve İngilizce karşılığını girebilirsiniz; İngilizce boş bırakılırsa o dilde Türkçesi gösterilir.</p>

@if (TempData["Message"] is string msg)
{
    <p class="admin-notice" role="status">@msg</p>
}
@if (Model.ErrorMessage is not null)
{
    <p class="admin-alert" role="alert">@Model.ErrorMessage</p>
}

<form method="post" class="admin-form admin-form-wide">
    <div class="admin-field">
        <label for="heroname">İsim (hero'da büyük görünen)</label>
        <input id="heroname" name="Values[hero.name]" value="@Model.V("hero.name")" />
    </div>

    <div class="admin-field-row">
        <div class="admin-field admin-field-grow">
            <label for="hero">Hero cümlesi — Türkçe</label>
            <textarea id="hero" name="Values[hero.tagline]" rows="2">@Model.V("hero.tagline")</textarea>
        </div>
        <div class="admin-field admin-field-grow">
            <label for="heroen">Hero cümlesi — English</label>
            <textarea id="heroen" name="Values[hero.tagline.en]" rows="2">@Model.V("hero.tagline.en")</textarea>
        </div>
    </div>

    <div class="admin-field-row">
        <div class="admin-field admin-field-grow">
            <label for="about">Hakkımda — Türkçe</label>
            <textarea id="about" name="Values[about.text]" rows="6">@Model.V("about.text")</textarea>
        </div>
        <div class="admin-field admin-field-grow">
            <label for="abouten">Hakkımda — English</label>
            <textarea id="abouten" name="Values[about.text.en]" rows="6">@Model.V("about.text.en")</textarea>
        </div>
    </div>

    <fieldset class="admin-fieldset">
        <legend>Çalışma ilkeleri</legend>
        @for (var i = 1; i <= 3; i++)
        {
            <div class="admin-field-row">
                <div class="admin-field">
                    <label for="p@(i)t">@i. ilke başlığı — TR</label>
                    <input id="p@(i)t" name="Values[principle.@(i).title]" value="@Model.V($"principle.{i}.title")" />
                </div>
                <div class="admin-field">
                    <label for="p@(i)te">@i. ilke başlığı — EN</label>
                    <input id="p@(i)te" name="Values[principle.@(i).title.en]" value="@Model.V($"principle.{i}.title.en")" />
                </div>
            </div>
            <div class="admin-field-row">
                <div class="admin-field admin-field-grow">
                    <label for="p@(i)x">@i. ilke açıklaması — TR</label>
                    <textarea id="p@(i)x" name="Values[principle.@(i).text]" rows="2">@Model.V($"principle.{i}.text")</textarea>
                </div>
                <div class="admin-field admin-field-grow">
                    <label for="p@(i)xe">@i. ilke açıklaması — EN</label>
                    <textarea id="p@(i)xe" name="Values[principle.@(i).text.en]" rows="2">@Model.V($"principle.{i}.text.en")</textarea>
                </div>
            </div>
            @if (i < 3)
            {
                <hr class="admin-sep" />
            }
        }
    </fieldset>

    <div class="admin-actions">
        <button type="submit" class="admin-btn admin-btn-primary">Kaydet</button>
    </div>
</form>
