@page "/proje/{slug}"
@using System.Text.Json
@using Portfolio.Web.Common
@model ProjeModel
@{
    ViewData["Title"] = $"{Model.Project.Title} — Emin";
    ViewData["Description"] = Model.Project.Summary;
    ViewData["OgType"] = "article";
    ViewData["Canonical"] = $"/proje/{Model.Project.Slug}";

    var jsonLd = JsonSerializer.Serialize(new Dictionary<string, object?>
    {
        ["@context"] = "https://schema.org",
        ["@type"] = "CreativeWork",
        ["name"] = Model.Project.Title,
        ["description"] = Model.Project.Summary,
        ["dateModified"] = Model.Project.UpdatedAt.ToString("yyyy-MM-dd"),
        ["keywords"] = string.Join(", ", Model.Project.TechStack),
        ["url"] = $"{Request.Scheme}://{Request.Host}/proje/{Model.Project.Slug}"
    });
}

@section Head {
    <script type="application/ld+json">@Html.Raw(jsonLd)</script>
}

<article class="project-detail container">
    <nav class="crumbs mono" aria-label="Sayfa yolu">
        <a href="/">ana sayfa</a><span aria-hidden="true"> / </span><a href="/#projeler">projeler</a><span aria-hidden="true"> / </span><span aria-current="page">@Model.Project.Slug</span>
    </nav>

    <header class="project-detail-head">
        <h1>@Model.Project.Title</h1>
        <p class="project-detail-summary">@Model.Project.Summary</p>

        <ul class="tech-list" aria-label="Kullanılan teknolojiler">
            @foreach (var (tech, ti) in Model.Project.TechStack.Select((t, i) => (t, i)))
            {
                var tipId = $"tip-detay-{ti}";
                <li>
                    <span class="tech-badge mono" tabindex="0" aria-describedby="@tipId">
                        @tech
                        <span class="tip" role="tooltip" id="@tipId">@TechGlossary.Describe(tech)</span>
                    </span>
                </li>
            }
        </ul>
    </header>

    @if (Model.Project.CoverImageUrl is not null)
    {
        <img class="project-cover" src="@Model.Project.CoverImageUrl" alt="@Model.Project.Title ekran görüntüsü"
             loading="lazy" width="1200" height="675" />
    }

    <div class="story">
        <section class="story-block reveal" aria-labelledby="sorun-b">
            <h2 id="sorun-b"><span class="story-no mono" aria-hidden="true">01</span> Sorun</h2>
            <p>@Model.Project.Problem</p>
        </section>
        <section class="story-block reveal" aria-labelledby="yaklasim-b">
            <h2 id="yaklasim-b"><span class="story-no mono" aria-hidden="true">02</span> Yaklaşım</h2>
            <p>@Model.Project.Approach</p>
        </section>
        <section class="story-block reveal" aria-labelledby="sonuc-b">
            <h2 id="sonuc-b"><span class="story-no mono" aria-hidden="true">03</span> Sonuç</h2>
            <p>@Model.Project.Outcome</p>
        </section>
    </div>

    @if (Model.Project.DemoUrl is not null || Model.Project.RepoUrl is not null)
    {
        <div class="project-links">
            @if (Model.Project.DemoUrl is not null)
            {
                <a class="btn-primary" href="@Model.Project.DemoUrl" rel="noopener">Canlı demoyu gör</a>
            }
            @if (Model.Project.RepoUrl is not null)
            {
                <a class="btn-ghost mono" href="@Model.Project.RepoUrl" rel="noopener">Kaynak kodu →</a>
            }
        </div>
    }

    <p class="project-back"><a href="/#projeler">← Tüm projelere dön</a></p>
</article>
