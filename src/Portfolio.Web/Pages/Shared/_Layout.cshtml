@inject Portfolio.Web.Features.Content.GetSiteContent.GetSiteContentHandler ContentHandler
@{
    var content = await ContentHandler.HandleAsync();
    var linkedin = content.GetValueOrDefault(Portfolio.Web.Domain.SiteContentKeys.SocialLinkedin);
    var github = content.GetValueOrDefault(Portfolio.Web.Domain.SiteContentKeys.SocialGithub);
    var email = content.GetValueOrDefault(Portfolio.Web.Domain.SiteContentKeys.ContactEmail);
    var cvFile = content.GetValueOrDefault(Portfolio.Web.Domain.SiteContentKeys.CvFile);

    var isHub = ViewData["IsHub"] as bool? ?? false;
    var culture = Loc.Culture;
    var returnUrl = Uri.EscapeDataString(Context.Request.Path + Context.Request.QueryString);
    var defaultDesc = "Karmaşık problemleri, insanların severek kullandığı basit yazılımlara dönüştüren yazılım mühendisi.";
}
<!DOCTYPE html>
<html lang="@culture">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@(ViewData["Title"] is string t && t.Length > 0 ? t : "Emin — Yazılım Mühendisi")</title>
    <meta name="description" content="@(ViewData["Description"] ?? defaultDesc)" />

    <meta property="og:type" content="@(ViewData["OgType"] ?? "website")" />
    <meta property="og:title" content="@(ViewData["Title"] ?? "Emin — Yazılım Mühendisi")" />
    <meta property="og:description" content="@(ViewData["Description"] ?? defaultDesc)" />
    <meta property="og:locale" content="@(culture == "en" ? "en_US" : "tr_TR")" />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content="@(ViewData["Title"] ?? "Emin — Yazılım Mühendisi")" />
    <meta name="twitter:description" content="@(ViewData["Description"] ?? defaultDesc)" />

    @if (ViewData["Canonical"] is string canonicalPath)
    {
        var canonicalUrl = $"{Context.Request.Scheme}://{Context.Request.Host}{canonicalPath}";
        <link rel="canonical" href="@canonicalUrl" />
        <meta property="og:url" content="@canonicalUrl" />
    }

    <link rel="icon" href="~/favicon.ico" sizes="any" />
    <link rel="preload" href="~/fonts/sora-latin-700.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="~/fonts/inter-latin-400.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="~/fonts/inter-latin-ext-400.woff2" as="font" type="font/woff2" crossorigin />

    @* Tema, CSS'ten önce belirlenir; açılışta yanlış tema parlaması (FOUC) yaşanmaz. *@
    <script nonce="@Context.GetNonce()">
        (function () {
            try {
                var fromUrl = new URLSearchParams(location.search).get("tema");
                var theme = (fromUrl === "dark" || fromUrl === "light")
                    ? fromUrl
                    : localStorage.getItem("theme");
                if (theme === "dark" || theme === "light")
                    document.documentElement.setAttribute("data-theme", theme);
            } catch (e) { /* localStorage kapalıysa sistem tercihi geçerli */ }
        })();
    </script>

    <link rel="stylesheet" href="~/css/fonts.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/tokens.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    @await RenderSectionAsync("Head", required: false)
</head>
<body class="@(isHub ? "is-hub" : "is-inner")">
    <a class="skip-link" href="#icerik">@T("skip")</a>

    @* İmza doku: arka planda akan kod yağmuru. reduced-motion'da JS başlatmaz. *@
    <canvas id="kodYagmuru" class="code-rain" aria-hidden="true"></canvas>

    <header class="site-header">
        <div class="container site-header-inner">
            <a class="brand mono" href="/" aria-label="@T("home")">e/</a>

            @if (!isHub)
            {
                <nav class="site-nav" aria-label="@T("home")">
                    <a href="/projeler">@T("nav.projects")</a>
                    <a href="/hakkimda">@T("nav.about")</a>
                    <a href="/iletisim">@T("nav.contact")</a>
                </nav>
            }

            <div class="header-actions">
                <div class="social-cluster">
                    @if (!string.IsNullOrEmpty(linkedin))
                    {
                        <a class="icon-btn" href="@linkedin" target="_blank" rel="noopener noreferrer" aria-label="@T("social.linkedin")" title="LinkedIn">
                            <svg aria-hidden="true" width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M6.94 5a2 2 0 1 1-4-.02 2 2 0 0 1 4 .02M7 8.48H3V21h4zm6.32 0H9.34V21h3.94v-6.57c0-3.66 4.77-4 4.77 0V21H22v-7.93c0-6.17-7.06-5.94-8.72-2.91z"/></svg>
                        </a>
                    }
                    @if (!string.IsNullOrEmpty(github))
                    {
                        <a class="icon-btn" href="@github" target="_blank" rel="noopener noreferrer" aria-label="@T("social.github")" title="GitHub">
                            <svg aria-hidden="true" width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2A10 10 0 0 0 2 12c0 4.42 2.87 8.17 6.84 9.5.5.08.66-.22.66-.48v-1.7c-2.78.6-3.37-1.34-3.37-1.34-.46-1.16-1.11-1.47-1.11-1.47-.9-.62.07-.6.07-.6 1 .07 1.53 1.03 1.53 1.03.89 1.52 2.34 1.08 2.91.83.09-.65.35-1.09.63-1.34-2.22-.25-4.55-1.11-4.55-4.94 0-1.09.39-1.98 1.03-2.68-.1-.25-.45-1.27.1-2.65 0 0 .84-.27 2.75 1.02a9.5 9.5 0 0 1 5 0c1.91-1.29 2.75-1.02 2.75-1.02.55 1.38.2 2.4.1 2.65.64.7 1.03 1.59 1.03 2.68 0 3.84-2.34 4.68-4.57 4.93.36.31.68.92.68 1.85v2.74c0 .27.16.57.67.48A10 10 0 0 0 22 12 10 10 0 0 0 12 2"/></svg>
                        </a>
                    }
                    @if (!string.IsNullOrEmpty(email))
                    {
                        <a class="icon-btn" href="mailto:@email" aria-label="@T("social.email")" title="@email">
                            <svg aria-hidden="true" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="5" width="18" height="14" rx="2"/><path d="m3 7 9 6 9-6"/></svg>
                        </a>
                    }
                    @if (!string.IsNullOrEmpty(cvFile))
                    {
                        <a class="cv-btn mono" href="@cvFile" target="_blank" rel="noopener" aria-label="@T("cv.aria")" download>
                            <svg aria-hidden="true" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3v12m0 0 4-4m-4 4-4-4"/><path d="M4 17v2a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-2"/></svg>
                            @T("cv")
                        </a>
                    }
                </div>

                <div class="lang-switch mono" role="group" aria-label="@T("lang.toggle")">
                    @foreach (var c in Loc.Supported)
                    {
                        if (c == culture)
                        {
                            <span class="lang-active" aria-current="true">@c.ToUpperInvariant()</span>
                        }
                        else
                        {
                            <a href="/dil/@c?returnUrl=@returnUrl">@c.ToUpperInvariant()</a>
                        }
                    }
                </div>

                <button type="button" class="theme-toggle" id="temaDugmesi"
                        aria-label="@T("theme.toggle")" title="@T("theme.toggle")">
                    <svg class="theme-icon theme-icon-sun" aria-hidden="true" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
                        <circle cx="12" cy="12" r="4"/><path d="M12 2v2m0 16v2M4.9 4.9l1.4 1.4m11.4 11.4 1.4 1.4M2 12h2m16 0h2M4.9 19.1l1.4-1.4M17.7 6.3l1.4-1.4"/>
                    </svg>
                    <svg class="theme-icon theme-icon-moon" aria-hidden="true" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M21 12.8A9 9 0 1 1 11.2 3a7 7 0 0 0 9.8 9.8Z"/>
                    </svg>
                </button>
            </div>
        </div>
    </header>

    <main id="icerik">
        @RenderBody()
    </main>

    @if (!isHub)
    {
        <footer class="site-footer">
            <div class="container site-footer-inner">
                <span class="mono">© @DateTime.Now.Year</span>
                <span>@T("footer")</span>
            </div>
        </footer>
    }

    <script type="module" src="~/js/main.js" asp-append-version="true"></script>
</body>
</html>
