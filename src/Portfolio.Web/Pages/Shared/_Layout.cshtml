<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@(ViewData["Title"] is string t && t.Length > 0 ? t : "Emin — Yazılım Mühendisi")</title>
    <meta name="description" content="@(ViewData["Description"] ?? "Karmaşık problemleri, insanların severek kullandığı basit yazılımlara dönüştüren yazılım mühendisi.")" />

    <meta property="og:type" content="@(ViewData["OgType"] ?? "website")" />
    <meta property="og:title" content="@(ViewData["Title"] ?? "Emin — Yazılım Mühendisi")" />
    <meta property="og:description" content="@(ViewData["Description"] ?? "Karmaşık problemleri, insanların severek kullandığı basit yazılımlara dönüştüren yazılım mühendisi.")" />
    <meta property="og:locale" content="tr_TR" />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content="@(ViewData["Title"] ?? "Emin — Yazılım Mühendisi")" />
    <meta name="twitter:description" content="@(ViewData["Description"] ?? "Karmaşık problemleri, insanların severek kullandığı basit yazılımlara dönüştüren yazılım mühendisi.")" />

    @* Tema, CSS'ten önce belirlenir; açılışta yanlış tema parlaması (FOUC) yaşanmaz. *@
    <script>
        (function () {
            try {
                var fromUrl = new URLSearchParams(location.search).get("tema");
                var theme = (fromUrl === "dark" || fromUrl === "light")
                    ? fromUrl
                    : localStorage.getItem("theme");
                if (theme === "dark" || theme === "light")
                    document.documentElement.setAttribute("data-theme", theme);
            } catch (e) { /* localStorage kapalıysa sistem tercihi geçerli */ }
        })();
    </script>

    <link rel="stylesheet" href="~/css/fonts.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/tokens.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    @await RenderSectionAsync("Head", required: false)
</head>
<body>
    <a class="skip-link" href="#icerik">İçeriğe atla</a>

    <header class="site-header">
        <div class="container site-header-inner">
            <a class="brand mono" href="/" aria-label="Ana sayfa">e/</a>
            <nav class="site-nav" aria-label="Site menüsü">
                <a href="/#projeler">Projeler</a>
                <a href="/#nasil-calisirim">Nasıl çalışırım</a>
                <a href="/#iletisim">İletişim</a>
            </nav>
            <button type="button" class="theme-toggle" id="temaDugmesi"
                    aria-label="Koyu/açık tema değiştir" title="Tema değiştir">
                <svg class="theme-icon theme-icon-sun" aria-hidden="true" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
                    <circle cx="12" cy="12" r="4"/><path d="M12 2v2m0 16v2M4.9 4.9l1.4 1.4m11.4 11.4 1.4 1.4M2 12h2m16 0h2M4.9 19.1l1.4-1.4M17.7 6.3l1.4-1.4"/>
                </svg>
                <svg class="theme-icon theme-icon-moon" aria-hidden="true" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M21 12.8A9 9 0 1 1 11.2 3a7 7 0 0 0 9.8 9.8Z"/>
                </svg>
            </button>
        </div>
    </header>

    <main id="icerik">
        @RenderBody()
    </main>

    <footer class="site-footer">
        <div class="container site-footer-inner">
            <span class="mono">© @DateTime.Now.Year</span>
            <span>El yazımı CSS ve sade JavaScript ile, framework'süz yapıldı.</span>
        </div>
    </footer>

    <script type="module" src="~/js/main.js" asp-append-version="true"></script>
</body>
</html>
