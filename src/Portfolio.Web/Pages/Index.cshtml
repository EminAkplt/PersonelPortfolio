@page
@using Portfolio.Web.Domain
@model IndexModel
@{
    var heroName = Model.Texts.Localized(SiteContentKeys.HeroName, "Emin");
    var tagline = Model.Texts.Localized(SiteContentKeys.HeroTagline);
    ViewData["Title"] = $"{heroName} — {(Culture == "en" ? "Software Engineer" : "Yazılım Mühendisi")}";
    ViewData["Description"] = tagline;
    ViewData["Canonical"] = "/";
    ViewData["IsHub"] = true;

    var menu = new (string Href, string Label, string Desc)[]
    {
        ("/projeler", T("nav.projects"), T("hub.projects.desc")),
        ("/hakkimda", T("nav.about"), T("hub.about.desc")),
        ("/iletisim", T("nav.contact"), T("hub.contact.desc")),
    };
}

<section class="hub">
    <div class="hub-inner">
        <div class="hub-intro">
            <p class="hub-eyebrow mono">@T("hub.eyebrow")</p>
            <h1 class="hub-name">@heroName<span class="hub-cursor" aria-hidden="true">_</span></h1>
            <p class="hub-tagline">@tagline</p>
            <span id="durumRozeti" class="status-badge mono" data-endpoint="/api/health"
                  data-ok="@T("hub.status.ok")" data-down="@T("hub.status.down")" data-offline="@T("hub.status.offline")">
                <span class="status-dot" aria-hidden="true"></span>
                <span class="status-text">@T("hub.status.ok")</span>
            </span>
        </div>

        <nav class="hub-menu" aria-label="@T("hub.enter")">
            @foreach (var (item, index) in menu.Select((m, i) => (m, i)))
            {
                <a class="hub-link" href="@item.Href">
                    <span class="hub-link-no mono" aria-hidden="true">@($"{index + 1:00}")</span>
                    <span class="hub-link-body">
                        <span class="hub-link-label">@item.Label</span>
                        <span class="hub-link-desc">@item.Desc</span>
                    </span>
                    <span class="hub-link-arrow mono" aria-hidden="true">→</span>
                </a>
            }
        </nav>
    </div>
</section>
