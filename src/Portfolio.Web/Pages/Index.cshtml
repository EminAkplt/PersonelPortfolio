@page
@using Portfolio.Web.Domain
@model IndexModel
@{
    var heroName = Model.Texts.Localized(SiteContentKeys.HeroName, "Emin");
    var tagline = Model.Texts.Localized(SiteContentKeys.HeroTagline);
    var consoleText = Model.Texts.Localized(SiteContentKeys.ConsoleText);
    var consoleLines = consoleText.Replace("\r\n", "\n").Split('\n');
    var promptUser = (heroName.Length > 0 ? heroName.ToLowerInvariant() : "emin") + "@portfolio";

    ViewData["Title"] = $"{heroName} — {(Culture == "en" ? "Software Engineer" : "Yazılım Mühendisi")}";
    ViewData["Description"] = tagline;
    ViewData["Canonical"] = "/";
    ViewData["IsHub"] = true;
}

<section class="hub">
    <div class="hub-grid">
        <div class="hub-intro">
            <p class="hub-eyebrow mono">@T("hub.eyebrow")</p>
            <h1 class="hub-name">@heroName<span class="hub-cursor" aria-hidden="true">_</span></h1>
            <p class="hub-tagline">@tagline</p>
            <span id="durumRozeti" class="status-badge mono" data-endpoint="/api/health"
                  data-ok="@T("hub.status.ok")" data-down="@T("hub.status.down")" data-offline="@T("hub.status.offline")">
                <span class="status-dot" aria-hidden="true"></span>
                <span class="status-text">@T("hub.status.ok")</span>
            </span>
        </div>

        <div class="console" aria-label="@(Culture == "en" ? "Short CV" : "Kısa özgeçmiş")">
            <div class="console-bar" aria-hidden="true">
                <span class="console-dots"><i></i><i></i><i></i></span>
                <span class="console-title mono">@promptUser: ~</span>
            </div>
            <div class="console-body mono">
                <p class="console-cmd"><span class="console-prompt">$</span> cat ozgecmis.txt</p>
                <div class="console-out">
                    @foreach (var line in consoleLines)
                    {
                        var trimmed = line.TrimStart();
                        var isComment = trimmed.StartsWith('#');
                        <span class="console-line @(isComment ? "is-comment" : "")">@(line.Length == 0 ? " " : line)</span>
                    }
                </div>
                <p class="console-cmd"><span class="console-prompt">$</span> <span class="console-caret" aria-hidden="true">▋</span></p>
            </div>
        </div>
    </div>
</section>
