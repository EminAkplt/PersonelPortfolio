<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex, nofollow" />
    <title>@(ViewData["Title"] is string t ? $"{t} — Yönetim" : "Yönetim")</title>
    <link rel="stylesheet" href="~/css/admin.css" asp-append-version="true" />
</head>
<body class="admin">
    @if (User.Identity?.IsAuthenticated == true)
    {
        <header class="admin-header">
            <span class="admin-brand">Portfolio Yönetimi</span>
            <nav class="admin-nav" aria-label="Yönetim menüsü">
                <a href="/admin">Özet</a>
                <a href="/admin/projeler">Projeler</a>
                <a href="/admin/mesajlar">Mesajlar</a>
                <a href="/admin/icerik">İçerik</a>
                <a href="/admin/baglantilar">Bağlantılar</a>
                <a href="/admin/simdi">Şu An</a>
            </nav>
            <form method="post" asp-page="/Admin/Index" asp-page-handler="Logout" class="admin-logout">
                <button type="submit">Çıkış</button>
            </form>
        </header>
    }
    <main class="admin-main">
        @RenderBody()
    </main>
</body>
</html>
