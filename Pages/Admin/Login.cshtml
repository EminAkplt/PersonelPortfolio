@page "/admin/giris"
@model Portfolio.Web.Pages.Admin.LoginModel
@{
    ViewData["Title"] = "Giriş";
}

<div class="admin-login-wrap">
    <h1>Yönetim Girişi</h1>

    @if (Model.ErrorMessage is not null)
    {
        <p class="admin-alert" role="alert">@Model.ErrorMessage</p>
    }

    <form method="post" class="admin-form">
        <div class="admin-field">
            <label asp-for="Username">Kullanıcı adı</label>
            <input asp-for="Username" autocomplete="username" required />
        </div>
        <div class="admin-field">
            <label asp-for="Password">Şifre</label>
            <input asp-for="Password" type="password" autocomplete="current-password" required />
        </div>
        <button type="submit" class="admin-btn admin-btn-primary">Giriş yap</button>
    </form>
</div>
